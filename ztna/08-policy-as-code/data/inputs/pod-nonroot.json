{
  "apiVersion": "v1",
  "kind": "Pod",
  "metadata": {
    "name": "nonroot-pod",
    "namespace": "default"
  },
  "spec": {
    "securityContext": {
      "runAsUser": 1000,
      "runAsNonRoot": true
    },
    "containers": [
      {
        "name": "app",
        "image": "nginx:1.27.3",
        "securityContext": {
          "runAsUser": 1000,
          "allowPrivilegeEscalation": false,
          "readOnlyRootFilesystem": true
        }
      }
    ]
  }
}
