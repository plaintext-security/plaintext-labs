  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "identityProviders": [],
  "roles": {
    "realm": [
      {
        "name": "analyst",
        "description": "Security analyst — read access to dashboards and logs",
        "composite": false
      },
      {
        "name": "admin",
        "description": "Security administrator — full access including configuration changes",
        "composite": false
      }
    ]
  },
  "users": [
    {
      "username": "analyst",
      "enabled": true,
      "email": "analyst@meridian.local",
      "firstName": "Sam",
      "lastName": "Analyst",
      "credentials": [
        {
          "type": "password",
          "value": "analyst123",
          "temporary": false
        }
      ],
      "realmRoles": ["analyst"]
    },
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@meridian.local",
