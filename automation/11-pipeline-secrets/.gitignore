# Runtime artifacts — never commit minted tokens, signing keys, or fetched creds.
__pycache__/
*.pyc
*.pem
*.key
*.jwt
# the OIDC provider's signing key + published JWKS (generated by mint_oidc_token.py)
data/oidc/
# the deploy role ARN written by setup.sh, and any minted-credential dumps
data/role-arn.txt
oidc-creds.json
creds.json
findings.md
