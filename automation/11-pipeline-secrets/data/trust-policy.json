{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowOnlyTheIntendedPipelineToFederate",
      "Effect": "Allow",
      "Principal": {
        "Federated": "arn:aws:iam::000000000000:oidc-provider/oidc-provider:8080"
      },
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Condition": {
        "StringEquals": {
          "oidc-provider:8080:aud": "sts.amazonaws.com",
          "oidc-provider:8080:sub": "repo:meridian/api:ref:refs/heads/main"
        }
      }
    }
  ]
}
